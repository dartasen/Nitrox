<Styles xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Border.installationList">
        <Setter Property="Background" Value="#0D0E13" />
        <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="Button.installationOption">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="MinHeight" Value="74" />
        <Setter Property="FocusAdorner" Value="{x:Null}" />

        <Style Selector="^ TextBlock">
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="TextAlignment" Value="Left" />
        </Style>

        <Style Selector="^:pointerover">
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="^:pressed">
            <Setter Property="Opacity" Value="1" />
        </Style>
    </Style>

    <Style Selector="Button.installationOption Border.installationRow">
        <Setter Property="Background" Value="#111219" />
        <Setter Property="Padding" Value="18,10" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.08" />
                <DoubleTransition Property="Opacity" Duration="0:0:0.08" />
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="Button.installationOption:pointerover Border.installationRow">
        <Setter Property="Background" Value="#1A1B24" />
    </Style>

    <Style Selector="Button.installationOption.selected Border.installationRow">
        <Setter Property="Background" Value="#20283A" />
    </Style>

    <Style Selector="Button.installationOption:nth-child(2n) Border.installationRow">
        <Setter Property="Background" Value="#181A22" />
    </Style>

    <Style Selector="Button.installationOption:nth-child(2n).selected Border.installationRow">
        <Setter Property="Background" Value="#273049" />
    </Style>

    <Style Selector="Button.installationOption:focus Border.installationRow">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandPrimary}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.installationOption:focus.selected Border.installationRow">
        <Setter Property="BorderBrush" Value="{DynamicResource BrandPrimary}" />
        <Setter Property="BorderThickness" Value="2" />
    </Style>

    <Style Selector="Ellipse.installationRadioOuter">
        <Setter Property="Width" Value="16" />
        <Setter Property="Height" Value="16" />
        <Setter Property="Fill" Value="#F2F2F2" />
    </Style>

    <Style Selector="Ellipse.installationRadioInner">
        <Setter Property="Width" Value="8" />
        <Setter Property="Height" Value="8" />
        <Setter Property="Fill" Value="{DynamicResource BrandPrimary}" />
        <Setter Property="Opacity" Value="0" />
    </Style>

    <Style Selector="Button.installationOption.selected Ellipse.installationRadioInner">
        <Setter Property="Opacity" Value="1" />
    </Style>
</Styles>
